<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01//EN" "http://www.w3.org/TR/html4/strict.dtd">
<html lang="en">

<head>
	<meta http-equiv="content-type" content="text/html; charset=UTF-8">
	<link href="https://unpkg.com/vuetify@1.0.17/dist/vuetify.min.css" type="text/css" rel="stylesheet">
	<link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700|Material+Icons" rel="stylesheet">
	<link rel="shortcut icon" href="<%= GLOBALS.LOGO %>">
	<title>
		<%= GLOBALS.APP_NAME %> API LIST
	</title>
	<style type="text/css">
		.medium-text {
			font-size: 18px;
			color: white;
		}

		.js div#preloader {
			position: fixed;
			left: 0;
			top: 0;
			z-index: 999;
			width: 100%;
			height: 100%;
			overflow: visible;
			/* background: #fff url('<%= GLOBALS.BASE_URL_WITHOUT_API %>images/') no-repeat center center; */
		}
	</style>
</head>

<body class="js">
	<div id="preloader"></div>
	<div id="app">
		<v-app id="inspire">
			<v-layout justify column>
				<v-flex style="margin:10px auto 10px auto; padding:0px; text-align:center;" center right sm2 xs2 md2 lg2
					xl2>
					<img src='<%= GLOBALS.LOGO %>' width="120px"><br>
					<strong style="font-size:24px;">
						<%= GLOBALS.APP_NAME %> API LIST
					</strong><br><br>
					<v-alert :value="true" outline color="white" style="padding:5px;">
						<v-chip color="black" text-color="white">
							<v-avatar>
								<v-icon>bookmark</v-icon>
							</v-avatar><b>TOTAL {{messages.length}} APIs</b>
						</v-chip>
					</v-alert>
					<v-alert :value="true" outline color="white" style="padding:5px;">
						<v-chip color="black" text-color="white">
							<v-avatar>
								<v-icon>label_important</v-icon>
							</v-avatar><b>All requests require API-KEY in header</b>
						</v-chip>
						<v-chip color="black" text-color="white">
							<v-avatar>
								<v-icon>label_important</v-icon>
							</v-avatar><b>Protected routes require token authentication</b>
						</v-chip>
					</v-alert>
				</v-flex>
				<v-flex style="margin:0px auto; padding:0px;" center right sm2 xs2 md2 lg2 xl2>
					<div id="main1" style="margin:0px auto; position:sticky;">
						<table border="0" cellpadding="10" cellspacing="10" width="100%"
							style="background: linear-gradient(150deg, #121213 50%, #1a1c27) !important;color: #fff;font-weight: bold;">
							<tr>
								<td><b>Server URL </b></td>
								<td>:&nbsp;&nbsp;<b>
										<%= GLOBALS.PORT_BASE_URL %>/api/v1/
									</b></td>
							</tr>
							<tr>
								<td><b>Header Parameters </b></td>
								<td>:&nbsp;&nbsp;<b>api-key(encrypted), token(encrypted), type('app'),
										accept-language('en'), timezone('Asia/Calcutta')</b></td>
							</tr>
							<tr>
								<td><b>API-KEY</b></td>
								<td>:&nbsp;&nbsp;<b>
										<%= GLOBALS.API_KEY %>
									</b></td>
							</tr>
							<tr>
								<td><b>Encryption Key</b></td>
								<td>:&nbsp;&nbsp;<b>
										<%= GLOBALS.KEY %>
									</b></td>
							</tr>
							<tr>
							<tr>
								<td><b>Encryption IV</b></td>
								<td>:&nbsp;&nbsp;<b>
										<%= GLOBALS.IV %>
									</b></td>
							</tr>
							<tr>
								<td><b>S3_BUCKET ROOT </b></td>
								<td>:&nbsp;&nbsp;<b>
										<%= GLOBALS.S3_BUCKET_ROOT %>
									</b></td>
							</tr>
							<tr>
								<td><b>S3_BUCKET FOLDER FOR USER PROFILE </b></td>
								<td>:&nbsp;&nbsp;<b>
										<%= GLOBALS.USER_IMAGE %>
									</b></td>
							</tr>
						</table>
						<br> <br>
					</div>
				</v-flex>
				<v-flex style="margin:0px auto;" center right sm2 xs2 md2 lg2 xl2>
					<a target="_blank" href='/v1/api_document/code'>
						<v-btn color="blue-grey" class="white--text">
							CODE REFERENCE <v-icon right dark>code</v-icon>
						</v-btn>
					</a>
					<!-- <a target="_blank" href='https://dev.pay4parky.com/enc_dec.php'> -->
					<a target="_blank" href='http://localhost/Project/VentureSessions/enc_dec.php'>
						<v-btn color="blue-grey" class="white--text">
							ENCRYPTION URL <v-icon right dark>lock</v-icon>
						</v-btn>
					</a>

				</v-flex>
				<v-expansion-panel popout>
					<v-expansion-panel-content v-for="(message, i) in messages" :key="i" hide-actions>
						<v-layout slot="header" align-center row spacer>
							<v-flex sm1 xs1 md1 lg1 xl1>
								<v-avatar slot="activator" size="36px">
									<v-icon :color="message.color">{{ message.icon }}</v-icon>
								</v-avatar>
							</v-flex>
							<v-flex sm3 xs3 md3 lg3 xl3>
								<strong v-html="message.title"></strong>
								<v-chip v-if="message.meth" :color="`${message.color} lighten-4`" label small
									class="ml-0">
									{{ message.meth }}
								</v-chip>
							</v-flex>
							<v-flex sm3 xs3 md3 lg3 xl3>
								<strong v-html="message.name"></strong><br>
								<span v-if="message.updated" style="color:orange">{{ message.updated }}</span>
								<span v-if="message.new_added" style="color:green"><span
										v-html="message.new_added"></span></span>
							</v-flex>
							<v-flex sm4 xs4 md4 lg4 xl4>
								<v-flex v-if="message.link" class="grey--text" ellipsis hidden-sm-and-down>
									{{ message.link }}
								</v-flex>
								<v-flex class="grey--text" ellipsis hidden-sm-and-down>
									<span v-if="message.imp" style="color:darkred">SHOW IMPORTANT NOTE INSIDE</span>
								</v-flex>
							</v-flex>
						</v-layout>
						<v-card dark>
							<v-container>
								<v-layout v-if="message.new_tag === '0'">
									<v-flex xs12 align-end flexbox>
										<v-alert v-if="message.new_added" :value="true" outline color="white"
											style="padding:5px;">
											<v-chip color="green" text-color="white">
												<v-avatar>
													<v-icon>fiber_new</v-icon>
												</v-avatar> NEW
											</v-chip>
											<span v-html="message.new_added"></span>
										</v-alert>
										<v-alert v-if="message.updated" :value="true" outline color="white"
											style="padding:5px;">
											<v-chip color="orange" text-color="white">
												<v-avatar>
													<v-icon>update</v-icon>
												</v-avatar> UPDATED
											</v-chip>
											<span>{{ message.updated }}</span>
										</v-alert>
										<v-alert :value="true" outline color="white" style="padding:5px;">
											<v-chip color="teal" text-color="white">
												<v-avatar>
													<v-icon>check_circle</v-icon>
												</v-avatar> MANDATORY
											</v-chip>
											<p v-html="message.mandatory" style="margin-left:10px;"></p>
										</v-alert>
										<v-alert :value="true" outline color="white" style="padding:5px;">
											<v-chip outline color="#F0F4C3">
												<v-avatar>
													<v-icon>check_circle</v-icon>
												</v-avatar>OPTIONAL
											</v-chip>
											<span>{{ message.optional }}
										</v-alert>
										<v-alert v-if="message.link" :value="true" outline color="white"
											style="padding:5px;">
											<v-chip color="light-green darken-2" text-color="white">
												<v-avatar>
													<v-icon>link</v-icon>
												</v-avatar> LINK
											</v-chip>
											<span>{{ message.link }}
										</v-alert>
										<v-alert v-if="message.imp" :value="true" outline color="white"
											style="padding:5px;">
											<v-chip color="red darken-2" text-color="white">
												<v-avatar>
													<v-icon>new_releases</v-icon>
												</v-avatar> IMPORTANT
											</v-chip>
											<p v-html="message.imp"></p>
										</v-alert>
										<v-alert v-if="message.notes" :value="true" outline color="white"
											style="padding:5px;">
											<v-chip color="blue lighten-1" text-color="white">
												<v-avatar>
													<v-icon>bookmark</v-icon>
												</v-avatar> NOTES
											</v-chip>
											<span>{{ message.notes }}
										</v-alert>
										<v-alert v-if="message.example" :value="true" outline color="white"
											style="padding:5px;">
											<v-chip color="red darken-2" text-color="white">
												<v-avatar>
													<v-icon>check_circle</v-icon>
												</v-avatar> EXAMPLE
											</v-chip>
											<p v-html="message.example"></p>
										</v-alert>
										<v-layout style="margin-top:-4px">
											<v-flex xs6 align-end flexbox>
												<v-alert :value="true" outline color="yellow" icon="priority_high"
													style="padding:5px;">
													<span class="grey--text">HEADER : {{ message.is_header }}, PUSH : {{
														message.is_push }}</span><br>
													<span>HEADER : {{ message.header }}</span>
												</v-alert>
											</v-flex>
											<v-flex xs6 align-end flexbox>
												<v-alert style="margin-left:4px; padding:5px;" :value="true" outline
													color="yellow" icon="priority_high">
													STATUS : <span v-html="message.status"></span>
												</v-alert>
											</v-flex>
										</v-layout>
									</v-flex>
								</v-layout>
							</v-container>
							<v-card-actions>
							</v-card-actions>
						</v-card>
					</v-expansion-panel-content>
				</v-expansion-panel>
			</v-layout>
		</v-app>
	</div>
	<div id="asd"></div>
	<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/vue@2.6.14/dist/vue.js"></script>
	<script src="https://unpkg.com/vuetify@1.0.17/dist/vuetify.min.js"></script>
	<script src="https://unpkg.com/babel-polyfill/dist/polyfill.min.js"></script>
	<script>

		jQuery(document).ready(function ($) {
			$('#preloader').fadeOut('slow', function () { $(this).remove(); });
		});

		var base_url = "<%= GLOBALS.PORT_BASE_URL %>/api/v1/";
		var base_url_without_api = "<%= GLOBALS.BASE_URL_WITHOUT_API %>";
		let i = 1;
		let j = 1;


		new Vue({
			el: '#app',
			data: () => ({
messages: [

    // ==================== USER AUTH APIs ====================
    {
        new_tag: '0',
        color: 'orange',
        icon: 'person_add',
        title: i++ + ' : User Auth',
        name: 'User Sign Up',
        meth: 'POST',
        link: base_url + "user/signup",
        mandatory: "signup_type, first_name, last_name, country_code, phone",
        optional: "email (required if signup_type=s), password (required if signup_type=s), social_id (required if signup_type=g/a/f), profile_image, fcm_token, device_type, device_name, os_version, app_version, timezone",
        is_header: "YES",
        is_push: "NO",
        header: "api-key",
        notes: "Register a new user. signup_type values: 's'=Standard, 'g'=Google, 'a'=Apple, 'f'=Facebook. Standard signup requires email + password. Social signup requires social_id; email/password are optional. OTP will be sent to the provided email after signup.",
        example: '{"signup_type":"s","first_name":"John","last_name":"Doe","email":"john@example.com","password":"secure123","country_code":"+1","phone":"1234567890","device_type":"A","os_version":"13.0","timezone":"Asia/Karachi"}',
        status: "<br>1. HTTP_OK[200] - code : 1 (Success - OTP sent)<br>2. HTTP_OK[200] - code : 0 (Validation error)<br>3. HTTP_OK[200] - code : 2 (Email already registered)",
        imp: "signup_type: 's'=Standard (email+password required), 'g'=Google, 'a'=Apple, 'f'=Facebook (social_id required). After signup, user must verify OTP via /verifyOtp before logging in."
    },
    {
        new_tag: '0',
        color: 'orange',
        icon: 'verified_user',
        title: i++ + ' : User Auth',
        name: 'User Verify OTP',
        meth: 'POST',
        link: base_url + "user/verifyOtp",
        mandatory: "email, otp, action",
        optional: "",
        is_header: "YES",
        is_push: "NO",
        header: "api-key",
        notes: "Verify the 4-digit OTP sent to the user's email. Used for both signup verification and forgot-password flow.",
        example: '{"email":"john@example.com","otp":"1234","action":"signup"}',
        status: "<br>1. HTTP_OK[200] - code : 1 (Success)<br>2. HTTP_OK[200] - code : 0 (Validation error)<br>3. HTTP_OK[200] - code : 3 (Invalid or expired OTP)",
        imp: "action must be 'signup' or 'forgot'. OTP is exactly 4 digits. OTP expires after a limited time - use /resendOtp if expired."
    },
    {
        new_tag: '0',
        color: 'orange',
        icon: 'login',
        title: i++ + ' : User Auth',
        name: 'User Login',
        meth: 'POST',
        link: base_url + "user/login",
        mandatory: "email, device_type, os_version, timezone",
        optional: "login_type (default: s), password (required if login_type=s), social_id (required if login_type=g/a/f), device_name, app_version, fcm_token, ip",
        is_header: "YES",
        is_push: "NO",
        header: "api-key",
        notes: "Authenticate a user. Standard login requires email + password. Social login requires email + social_id. Returns an auth token on success.",
        example: '{"login_type":"s","email":"john@example.com","password":"secure123","device_type":"A","os_version":"13.0","timezone":"Asia/Karachi"}',
        status: "<br>1. HTTP_OK[200] - code : 1 (Success - token returned)<br>2. HTTP_OK[200] - code : 0 (Validation error)<br>3. HTTP_OK[200] - code : 4 (Invalid email or password)<br>4. HTTP_OK[200] - code : 5 (Account not verified)",
        imp: "device_type: 'A'=Android, 'I'=iOS, 'W'=Web. The token returned must be sent in the header for all protected routes. Email must be verified before login is allowed."
    },
    {
        new_tag: '0',
        color: 'orange',
        icon: 'refresh',
        title: i++ + ' : User Auth',
        name: 'User Resend OTP',
        meth: 'POST',
        link: base_url + "user/resendOtp",
        mandatory: "email, action",
        optional: "",
        is_header: "YES",
        is_push: "NO",
        header: "api-key",
        notes: "Resend OTP to the user's email. Use when the previous OTP has expired or was not received.",
        example: '{"email":"john@example.com","action":"signup"}',
        status: "<br>1. HTTP_OK[200] - code : 1 (Success - new OTP sent)<br>2. HTTP_OK[200] - code : 0 (Validation error)<br>3. HTTP_OK[200] - code : 5 (Email not found)",
        imp: "action must be 'signup' or 'forgot'. Rate limiting may apply to prevent OTP abuse."
    },
    {
        new_tag: '0',
        color: 'orange',
        icon: 'lock_reset',
        title: i++ + ' : User Auth',
        name: 'User Forgot Password',
        meth: 'POST',
        link: base_url + "user/forgotPassword",
        mandatory: "email",
        optional: "",
        is_header: "YES",
        is_push: "NO",
        header: "api-key",
        notes: "Initiate password reset by sending an OTP to the user's email.",
        example: '{"email":"john@example.com"}',
        status: "<br>1. HTTP_OK[200] - code : 1 (Success - OTP sent)<br>2. HTTP_OK[200] - code : 0 (Validation error)<br>3. HTTP_OK[200] - code : 5 (Email not registered)",
        imp: "Flow: forgotPassword -> verifyOtp (action='forgot') -> resetPassword."
    },
    {
        new_tag: '0',
        color: 'orange',
        icon: 'lock',
        title: i++ + ' : User Auth',
        name: 'User Reset Password',
        meth: 'POST',
        link: base_url + "user/resetPassword",
        mandatory: "email, new_password",
        optional: "",
        is_header: "YES",
        is_push: "NO",
        header: "api-key",
        notes: "Set a new password after successful OTP verification. Must be called after /verifyOtp with action='forgot'.",
        example: '{"email":"john@example.com","new_password":"newSecure123"}',
        status: "<br>1. HTTP_OK[200] - code : 1 (Success)<br>2. HTTP_OK[200] - code : 0 (Validation error)<br>3. HTTP_OK[200] - code : 6 (OTP not verified yet)",
        imp: "new_password must be 6-50 characters. OTP must be verified (action='forgot') before calling this endpoint."
    },
    {
        new_tag: '0',
        color: 'orange',
        icon: 'logout',
        title: i++ + ' : User Auth',
        name: 'User Logout',
        meth: 'POST',
        link: base_url + "user/logout",
        mandatory: "",
        optional: "",
        is_header: "YES",
        is_push: "NO",
        header: "api-key, token",
        notes: "Invalidate the current user session. The token sent in the header will be revoked.",
        example: '{}',
        status: "<br>1. HTTP_OK[200] - code : 1 (Success)<br>2. HTTP_OK[200] - code : 0 (Error)<br>3. HTTP_OK[200] - code : 7 (Invalid or expired token)",
        imp: "Protected route - token required in header. Token is permanently invalidated after logout."
    },

    // ==================== USER PROFILE APIs ====================
    {
        new_tag: '0',
        color: 'blue',
        icon: 'account_circle',
        title: i++ + ' : User Profile',
        name: 'User Get Profile',
        meth: 'GET',
        link: base_url + "user/getProfile",
        mandatory: "",
        optional: "",
        is_header: "YES",
        is_push: "NO",
        header: "api-key, token",
        notes: "Retrieve the authenticated user's profile information including name, email, phone, profile image, DOB, location, and account status.",
        example: 'No body required. Send token in header.',
        status: "<br>1. HTTP_OK[200] - code : 1 (Success - profile data returned)<br>2. HTTP_OK[200] - code : 0 (Error)<br>3. HTTP_OK[200] - code : 7 (Invalid or expired token)",
        imp: "This is a GET request. No request body needed. Token must be sent in the Authorization header."
    },
    {
        new_tag: '0',
        color: 'blue',
        icon: 'edit',
        title: i++ + ' : User Profile',
        name: 'User Update Profile',
        meth: 'POST',
        link: base_url + "user/updateProfile",
        mandatory: "",
        optional: "first_name, last_name, profile_image, country_code, phone, email, dob, city, state, country",
        is_header: "YES",
        is_push: "NO",
        header: "api-key, token",
        notes: "Update one or more profile fields. Only fields provided in the request body will be updated. All fields are optional but at least one should be sent.",
        example: '{"first_name":"Johnny","last_name":"Doe","phone":"9876543210","dob":"1990-01-01","city":"Lahore","country":"Pakistan"}',
        status: "<br>1. HTTP_OK[200] - code : 1 (Success)<br>2. HTTP_OK[200] - code : 0 (Validation error)<br>3. HTTP_OK[200] - code : 7 (Invalid or expired token)",
        imp: "dob format: YYYY-MM-DD. phone must be 6-20 digits. country_code format: +1 to +999999. first_name and last_name must be 2-255 characters."
    },
    {
        new_tag: '0',
        color: 'blue',
        icon: 'password',
        title: i++ + ' : User Profile',
        name: 'User Change Password',
        meth: 'POST',
        link: base_url + "user/changePassword",
        mandatory: "old_password, new_password, confirm_password",
        optional: "",
        is_header: "YES",
        is_push: "NO",
        header: "api-key, token",
        notes: "Change the authenticated user's password. Requires the current (old) password for verification.",
        example: '{"old_password":"oldPass123","new_password":"newPass456","confirm_password":"newPass456"}',
        status: "<br>1. HTTP_OK[200] - code : 1 (Success)<br>2. HTTP_OK[200] - code : 0 (Validation error)<br>3. HTTP_OK[200] - code : 7 (Invalid token)<br>4. HTTP_OK[200] - code : 8 (Incorrect old password)",
        imp: "new_password must be 6-50 characters. confirm_password must exactly match new_password."
    },
    {
        new_tag: '0',
        color: 'blue',
        icon: 'delete_forever',
        title: i++ + ' : User Profile',
        name: 'User Delete Account',
        meth: 'POST',
        link: base_url + "user/deleteAccount",
        mandatory: "",
        optional: "",
        is_header: "YES",
        is_push: "NO",
        header: "api-key, token",
        notes: "Permanently delete the authenticated user's account and all associated data.",
        example: '{}',
        status: "<br>1. HTTP_OK[200] - code : 1 (Success - account deleted)<br>2. HTTP_OK[200] - code : 0 (Error)<br>3. HTTP_OK[200] - code : 7 (Invalid or expired token)",
        imp: "This action is irreversible. All user data, bookings, and activity history will be permanently removed."
    },

    // ==================== USER HOME APIs ====================
    {
        new_tag: '0',
        color: 'cyan',
        icon: 'home',
        title: i++ + ' : User Home',
        name: 'User Home Dashboard',
        meth: 'GET',
        link: base_url + "user/userHome",
        mandatory: "",
        optional: "address_id, category_id, search, limit, radius_km",
        is_header: "YES",
        is_push: "NO",
        header: "api-key, token",
        notes: "Returns customer home dashboard data in one response: selected/default location, service categories, nearby service providers, favorite services, and upcoming bookings.",
        example: '{"address_id":12,"category_id":2,"search":"hair","limit":20,"radius_km":15}',
        status: "<br>1. HTTP_OK[200] - code : 1 (Success)<br>2. HTTP_OK[200] - code : 0 (Validation error)<br>3. HTTP_OK[200] - code : 7 (Invalid or expired token)",
        imp: "Distance filter uses selected address latitude/longitude and applies nearby radius in KM. Defaults: limit=20, radius_km=50. radius_km range: 1-500."
    },
    {
        new_tag: '0',
        color: 'cyan',
        icon: 'photo',
        title: i++ + ' : User Home',
        name: 'Get Banner',
        meth: 'GET',
        link: base_url + "user/getBanner",
        mandatory: "",
        optional: "",
        is_header: "YES",
        is_push: "NO",
        header: "api-key, token",
        notes: "Returns active banner ads for customer/all audience where start/end date conditions match current time. Sorted by sort_order then latest id.",
        example: '{}',
        status: "<br>1. HTTP_OK[200] - code : 1 (Success)<br>2. HTTP_OK[200] - code : 0 (Error)<br>3. HTTP_OK[200] - code : 7 (Invalid or expired token)",
        imp: "Protected GET route. Only banners with is_active=true, is_deleted=false, valid date range, and target_audience in ('all','customer') are returned."
